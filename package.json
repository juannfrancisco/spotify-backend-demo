{
  "name": "znt-template-angular-tailwind-front",
  "displayName": "Template Angular",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run set-env:development && ng serve --ssl",
    "start:prod": "npm run set-env:production && ng serve --ssl --configuration production",
    "build": "npm run set-env:development && ng build --configuration production",
    "build:production": "npm run set-env:production && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --browsers=ChromeHeadless --watch=false",
    "test:coverage": "ng test --code-coverage --watch=false --browsers=ChromeHeadless",
    "test:ci": "ng test --code-coverage --watch=false --browsers=ChromeHeadless --reporters=progress,coverage",
    "sonar": "sonar-scanner",
    "test:e2e": "npx playwright test --ui",
    "prettier": "prettier --config ./.prettierrc --write \"src/{app,environments}/**/*{.ts,.html,.css,.json}\"",
    "prettier:verify": "prettier --config ./.prettierrc --check \"src/{app,environments}/**/*{.ts,.html,.css,.json}\"",
    "prettier:staged": "pretty-quick --staged",
    "lint": "ng lint",
    "lint:css": "stylelint \"src/**/*.css\" --config stylelint.config.js --fix",
    "set-env": "node set-env.js",
    "set-env:production": "npm run set-env -- --environment production",
    "set-env:development": "npm run set-env -- --environment development"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.1.4",
    "@angular/common": "^19.1.4",
    "@angular/compiler": "^19.1.4",
    "@angular/core": "^19.1.4",
    "@angular/forms": "^19.1.4",
    "@angular/material": "^19.1.4",
    "@angular/platform-browser": "^19.1.4",
    "@angular/platform-browser-dynamic": "^19.1.4",
    "@angular/router": "^19.1.4",
    "@auth0/angular-jwt": "^5.2.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.0.3",
    "@tailwindcss/typography": "^0.5.16",
    "angular-svg-icon": "^13.0.0",
    "apexcharts": "^4.5.0",
    "ng-apexcharts": "^1.7.1",
    "ngx-skeleton-loader": "^10.0.0",
    "ngx-sonner": "^3.0.0",
    "ngx-spinner": "^19.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^11.1.0",
    "yaml": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.5",
    "@angular-eslint/builder": "20.1.1",
    "@angular-eslint/eslint-plugin": "20.1.1",
    "@angular-eslint/eslint-plugin-template": "20.1.1",
    "@angular-eslint/schematics": "20.1.1",
    "@angular-eslint/template-parser": "20.1.1",
    "@angular/cli": "^19.1.5",
    "@angular/compiler-cli": "^19.1.4",
    "@playwright/test": "^1.50.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "angular-eslint": "^20.1.1",
    "autoprefixer": "^10.4.7",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "8.57.1",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "dotenv": "^17.2.3",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.1",
    "prettier": "^2.7.1",
    "prettier-plugin-tailwindcss": "^0.1.12",
    "stylelint": "^16.22.0",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwind-scrollbar": "^4.0.0",
    "tailwindcss": "^4.0.5",
    "typescript": "~5.7.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
